#!/usr/bin/env bash
# Shim so `blvim` resolves as a real executable on PATH, not just a zsh alias.
# Sources the pinned version from the repo's root `versions` file.
SCRIPT_PATH="$(readlink -f "$0")"
REPO_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
# shellcheck source=../versions
. "$REPO_ROOT/versions"
NVIM_APPNAME=blvim exec "/opt/nvim_${NVIM_VERSION}-linux64/bin/nvim" "$@"
